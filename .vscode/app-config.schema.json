{
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "port": {
          "type": "number",
          "minimum": 1,
          "maximum": 65535
        }
      },
      "required": [
        "port"
      ],
      "additionalProperties": false
    },
    "ui": {
      "type": "object",
      "properties": {
        "theme": {
          "type": "string",
          "enum": [
            "light",
            "dark"
          ]
        },
        "pages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "columns": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "size": {
                      "type": "number",
                      "minimum": 1,
                      "maximum": 12
                    },
                    "widgets": {
                      "type": "array",
                      "items": {
                        "anyOf": [
                          {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string",
                                "const": "weather"
                              },
                              "provider": {
                                "type": "string",
                                "enum": [
                                  "openmeteo",
                                  "weatherbit"
                                ],
                                "default": "openmeteo"
                              },
                              "geonames": {
                                "type": "object",
                                "properties": {
                                  "outputPath": {
                                    "type": "string",
                                    "default": "resources/geonames"
                                  },
                                  "dataset": {
                                    "type": "string",
                                    "enum": [
                                      "allCountries",
                                      "cities5000",
                                      "cities15000"
                                    ],
                                    "default": "cities15000"
                                  }
                                },
                                "additionalProperties": false,
                                "default": {
                                  "outputPath": "resources/geonames",
                                  "dataset": "cities15000"
                                }
                              },
                              "location": {
                                "type": "string"
                              },
                              "granularity": {
                                "type": "string",
                                "enum": [
                                  "daily",
                                  "hourly"
                                ],
                                "default": "daily"
                              },
                              "forecastDays": {
                                "type": "number",
                                "default": 5
                              },
                              "temperatureUnit": {
                                "type": "string",
                                "enum": [
                                  "C",
                                  "F"
                                ],
                                "default": "C"
                              }
                            },
                            "required": [
                              "type",
                              "location"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string",
                                "const": "air-quality"
                              },
                              "location": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "type",
                              "location"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string",
                                "const": "tabs"
                              },
                              "labels": {
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "tabs": {
                                "type": "array",
                                "items": {
                                  "$ref": "#/properties/ui/properties/pages/items/properties/columns/items/properties/widgets/items"
                                }
                              }
                            },
                            "required": [
                              "type",
                              "labels",
                              "tabs"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string",
                                "const": "reddit"
                              },
                              "subreddit": {
                                "type": "string"
                              },
                              "hideTitle": {
                                "type": "boolean",
                                "default": false
                              },
                              "sort": {
                                "type": "string",
                                "enum": [
                                  "hot",
                                  "new",
                                  "top",
                                  "rising"
                                ]
                              },
                              "limit": {
                                "type": "integer",
                                "exclusiveMinimum": 0,
                                "maximum": 20,
                                "default": 5
                              }
                            },
                            "required": [
                              "type",
                              "subreddit",
                              "sort"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string",
                                "const": "youtube"
                              },
                              "showTitle": {
                                "type": "boolean",
                                "default": true
                              },
                              "limit": {
                                "type": "number",
                                "minimum": 1,
                                "maximum": 50,
                                "default": 12
                              },
                              "channels": {
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              }
                            },
                            "required": [
                              "type",
                              "channels"
                            ],
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "properties": {
                              "type": {
                                "type": "string",
                                "const": "bookmark"
                              },
                              "title": {
                                "type": "string"
                              },
                              "bookmarks": {
                                "type": "array",
                                "items": {
                                  "anyOf": [
                                    {
                                      "type": "string",
                                      "format": "uri"
                                    },
                                    {
                                      "type": "object",
                                      "properties": {
                                        "title": {
                                          "type": "string"
                                        },
                                        "url": {
                                          "type": "string",
                                          "format": "uri"
                                        }
                                      },
                                      "required": [
                                        "title",
                                        "url"
                                      ],
                                      "additionalProperties": false
                                    }
                                  ]
                                }
                              },
                              "groups": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "title": {
                                      "$ref": "#/properties/ui/properties/pages/items/properties/columns/items/properties/widgets/items/anyOf/5/properties/title"
                                    },
                                    "bookmarks": {
                                      "$ref": "#/properties/ui/properties/pages/items/properties/columns/items/properties/widgets/items/anyOf/5/properties/bookmarks"
                                    },
                                    "groups": {
                                      "$ref": "#/properties/ui/properties/pages/items/properties/columns/items/properties/widgets/items/anyOf/5/properties/groups"
                                    }
                                  },
                                  "required": [
                                    "title"
                                  ],
                                  "additionalProperties": false
                                }
                              }
                            },
                            "required": [
                              "type",
                              "title"
                            ],
                            "additionalProperties": false
                          }
                        ]
                      }
                    }
                  },
                  "required": [
                    "size",
                    "widgets"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "title",
              "path",
              "columns"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "theme",
        "pages"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "server",
    "ui"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#"
}